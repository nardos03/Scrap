function normalizeHeader(value) {
  return String(value || '')
    .replace(/\u00A0/g, ' ')
    .replace(/\r?\n/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
}

function getRequiredSheet_(ss, sheetName) {
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    throw new Error(`Missing required sheet: ${sheetName}`);
  }
  return sheet;
}

function getHeaderMap(sheet) {
  const lastColumn = sheet.getLastColumn();
  if (lastColumn === 0) {
    throw new Error(`Sheet "${sheet.getName()}" has no columns.`);
  }

  const rawHeaders = sheet.getRange(1, 1, 1, lastColumn).getValues()[0];
  const normalizedHeaders = rawHeaders.map(h => normalizeHeader(h));
  const headerMap = {};

  normalizedHeaders.forEach((header, index) => {
    if (header && !(header in headerMap)) {
      headerMap[header] = index + 1; // 1-based column index
    }
  });

  Logger.log(`Sheet: ${sheet.getName()}`);
  Logger.log(`Raw row 1 headers: ${JSON.stringify(rawHeaders)}`);
  Logger.log(`Normalized row 1 headers: ${JSON.stringify(normalizedHeaders)}`);

  return {
    rawHeaders,
    normalizedHeaders,
    headerMap
  };
}

function requireHeader_(sheet, headerMapObj, requiredHeader) {
  const normalizedRequired = normalizeHeader(requiredHeader);
  const col = headerMapObj.headerMap[normalizedRequired];

  if (!col) {
    throw new Error(
      `Missing header in sheet "${sheet.getName()}". ` +
      `Expected: "${requiredHeader}". ` +
      `Normalized expected: "${normalizedRequired}". ` +
      `Found normalized headers: ${headerMapObj.normalizedHeaders.join(', ')}`
    );
  }

  return col;
}

function getGlobalVariablesMap_(globalInputsSheet) {
  const lastRow = globalInputsSheet.getLastRow();
  const lastColumn = globalInputsSheet.getLastColumn();
  if (lastRow < 2 || lastColumn < 2) {
    throw new Error('Global Inputs sheet does not contain enough data.');
  }

  const values = globalInputsSheet.getRange(1, 1, lastRow, lastColumn).getValues();
  const map = {};

  for (let i = 0; i < values.length; i++) {
    const key = String(values[i][0] || '').trim();
    const val = values[i][1];

    // Stop only on truly empty rows? No. Just ignore rows without keys.
    if (!key) continue;

    // We only want variables that look like <VarName>
    if (/^<.*>$/.test(key)) {
      map[key] = val;
    }
  }

  Logger.log(`Global variable keys found: ${JSON.stringify(Object.keys(map))}`);
  return map;
}

function replaceAngleBracketVariables_(value, globalVarsMap) {
  const text = String(value == null ? '' : value);
  return text.replace(/<[^>]+>/g, match => {
    return Object.prototype.hasOwnProperty.call(globalVarsMap, match)
      ? globalVarsMap[match]
      : match;
  });
}

